{
  "$schema": "https://schema.tauri.app/config/2",
  "productName": "Klaudio Panels",
  "version": "1.6.0",
  "identifier": "com.willywg.klaudio-panels",
  "build": {
    "beforeDevCommand": "bun run dev",
    "devUrl": "http://localhost:1420",
    "beforeBuildCommand": "bun run build",
    "frontendDist": "../dist"
  },
  "app": {
    "windows": [
      {
        "label": "main",
        "title": "Klaudio Panels",
        "width": 1200,
        "height": 800,
        "minWidth": 900,
        "minHeight": 600,
        "titleBarStyle": "Overlay",
        "hiddenTitle": true,
        "dragDropEnabled": true
      }
    ],
    "security": {
      "csp": null
    },
    "macOSPrivateApi": true
  },
  "bundle": {
    "active": true,
    "targets": "all",
    "icon": [
      "icons/32x32.png",
      "icons/128x128.png",
      "icons/128x128@2x.png",
      "icons/icon.icns",
      "icons/icon.ico"
    ],
    "macOS": {
      "entitlements": "./entitlements.plist",
      "signingIdentity": "-"
    },
    "resources": [
      "scripts/klaudio"
    ]
  },
  "plugins": {
    "deep-link": {
      "desktop": {
        "schemes": ["klaudio"]
      }
    }
  }
}
